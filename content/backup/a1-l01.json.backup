  "title": {
    "de": "Super!",
    "fa": "خیلی عالی!",
    "en": "Super!"
  },
  "shortTitle": {
    "de": "Hallo!",
    "fa": "سلام!",
    "en": "Hello!"
  },
  "description": {
    "fa": "در این درس با سلام و احوالپرسی، معرفی خود و بیان ملیت و زبان آشنا می‌شوید.",
    "en": "In this lesson you will learn greetings, introducing yourself and expressing nationality and language.",
    "de": "In dieser Lektion lernen Sie Begrüßungen, sich vorzustellen und Nationalität und Sprache auszudrücken."
  },
  "learningObjectives": {
    "fa": [
      "✅ یادگیری ۵ روش مختلف سلام کردن به آلمانی",
      "✅ گفتن اسم خود با فعل heißen",
      "✅ بیان ملیت و زبان خود",
      "✅ پرسیدن نام دیگران به صورت رسمی و غیررسمی"
    ],
    "en": [
      "✅ Learn 5 different ways to greet in German",
      "✅ Say your name with the verb 'heißen'",
      "✅ Express your nationality and language",
      "✅ Ask others' names formally and informally"
    ],
    "de": [
      "✅ 5 verschiedene Arten zu grüßen lernen",
      "✅ Sagen Sie Ihren Namen mit dem Verb 'heißen'",
      "✅ Nationalität und Sprache ausdrücken",
      "✅ Namen anderer formell und informell fragen"
    ]
  },
  "xpReward": 50,
  "perfectBonusXP": 25,
  "estimatedMinutes": 45,
  "difficulty": 1,
