# ============================================
# Node Environment
# ============================================
NODE_ENV=development
PORT=5001

# ============================================
# Database Configuration
# ============================================
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_LOGGING=true

# ============================================
# Admin User
# ============================================
ADMIN_EMAIL=admin@german-academy.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_12345678901234567890
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_MIN_32_CHARS_1234567890
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# AI Services
# ============================================
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
DEFAULT_AI_MODEL=gemini-2.0-flash
FALLBACK_AI_MODEL=openrouter/gpt-4o-mini

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================
# Email (Optional)
# ============================================
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@german-academy.com

# ============================================
# Session
# ============================================
SESSION_SECRET=CHANGE_ME_MIN_32_CHARS_SESSION_SECRET