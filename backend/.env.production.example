# backend/.env.production.example
# Path: backend/.env.production.example
# Description: Complete environment variables for production
# Version: 2.0 - Complete env variables

# ============================================
# 🌍 Application
# ============================================
NODE_ENV=production
PORT=5001
APP_NAME=Learning Academy
APP_VERSION=2.0.0
APP_URL=https://learning-academy.com
FRONTEND_URL=https://learning-academy.com
DOMAIN=learning-academy.com

# ============================================
# 🗄️ Database (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=german_academy
DB_USER=german_user
DB_PASSWORD=change_this_to_a_strong_password
DB_DIALECT=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_LOGGING=false

# ============================================
# 🟥 Redis
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change_this_to_a_strong_password
REDIS_PREFIX=la:

# ============================================
# 🔐 JWT Authentication
# ============================================
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 📧 Email (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Learning Academy <noreply@learning-academy.com>
EMAIL_REPLY_TO=support@learning-academy.com

# Alternative: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_PROVIDER=sendgrid

# Alternative: Mailgun
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.learning-academy.com
# EMAIL_PROVIDER=mailgun

# ============================================
# 🤖 AI Configuration
# ============================================
# Provider: openai | anthropic | local | mock
AI_PROVIDER=openai
AI_FALLBACK_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Anthropic (fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local LLM (Ollama)
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama2

# AI Rate Limits
AI_MAX_TOKENS_PER_USER_PER_DAY=10000
AI_RATE_LIMIT_PER_MINUTE=20

# ============================================
# 📊 Sentry (Error Tracking)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================
# 📈 Monitoring
# ============================================
# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9091

# ============================================
# 🚦 Rate Limiting
# ============================================
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_AI=20
RATE_LIMIT_STORIES=30
# Whitelist IPs (comma-separated)
RATE_LIMIT_WHITELIST=127.0.0.1,::1

# ============================================
# 📁 File Upload
# ============================================
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE=5242880
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Cloud Storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# 🔐 Security
# ============================================
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=https://learning-academy.com
COOKIE_SECRET=change_this_to_a_long_random_string
HELMET_ENABLED=true

# ============================================
# 📱 Notifications
# ============================================
# Slack webhook for critical alerts
SLACK_WEBHOOK_URL=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Push notifications (Web Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@learning-academy.com

# ============================================
# 🌐 External APIs
# ============================================
# Google Translate API (for dictionary)
GOOGLE_TRANSLATE_API_KEY=

# Text-to-Speech
TTS_PROVIDER=google
TTS_API_KEY=

# ============================================
# 📊 Analytics
# ============================================
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# ============================================
# 🔄 Webhooks
# ============================================
WEBHOOK_SECRET=

# ============================================
# 💾 Caching
# ============================================
CACHE_TTL=3600
CACHE_PREFIX=la:

# ============================================
# 📝 Logging
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ============================================
# 🛡️ Admin
# ============================================
ADMIN_EMAIL=admin@learning-academy.com
ADMIN_PASSWORD=change_this_to_a_strong_password

# ============================================
# 🔧 Feature Flags
# ============================================
FEATURE_AI_TUTOR=true
FEATURE_STORIES=true
FEATURE_SCENARIOS=true
FEATURE_ACHIEVEMENTS=true
FEATURE_LEADERBOARD=true
FEATURE_MENTORS=false
FEATURE_SPACED_REPETITION=true

# ============================================
# 🚀 Deployment
# ============================================
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY=

# ============================================
# 🧪 Testing
# ============================================
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_db
