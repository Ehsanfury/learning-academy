# ============================================
# 🚀 Learning Academy - PRODUCTION Environment
# ============================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.

# ============================================
# 🗄️ Database
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=german_academy
DB_USER=german_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_SSL=true
DB_SYNC=true

# ============================================
# 🔐 JWT — generate with: openssl rand -hex 32
# ============================================
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_different_from_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 🔐 Session
# ============================================
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ============================================
# 🤖 AI Services
# ============================================
GOOGLE_GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_AI_MODEL=gemini-2.0-flash
FALLBACK_AI_MODEL=openrouter/gpt-4o-mini

# ============================================
# 🌐 App
# ============================================
APP_URL=https://your-domain.com
API_URL=https://your-domain.com/api
NODE_ENV=production
PORT=5001

# ============================================
# 🔒 CORS — comma-separated, no trailing slash
# ============================================
CORS_ORIGIN=https://your-domain.com

# ============================================
# 📧 Email
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@your-domain.com

# ============================================
# 👑 Admin
# ============================================
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_at_least_12_chars

# ============================================
# 📊 Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# 🚦 Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================
# 🔴 Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
