{
  "name": "german-academy-backend",
  "version": "2.0.0",
  "description": "German Academy - AI-Powered Language Learning Platform Backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "load-lessons": "node scripts/loadLessonContent.js",
    "load-seeders": "node scripts/runSeeders.js",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "security:check": "npm audit",
    "env:validate": "node scripts/validateEnv.js",
    "streak:check": "node scripts/runStreakChecker.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "seed:lessons": "node scripts/runLessonSeeder.js",
    "seed:scenarios": "node scripts/seed-scenarios.js",
    "fix-order": "node scripts/fix-order.js",
    "seed:fix": "node scripts/runLessonSeeder.js && node scripts/fix-order.js",
    "db:check": "node -e \"import sequelize from './config/db.js'; await sequelize.authenticate(); const [r] = await sequelize.query('SELECT id, \\\"order\\\", total_sections FROM lessons WHERE id LIKE \\\"a1-l%\\\" ORDER BY \\\"order\\\"'); console.log('📊 Lessons:'); r.forEach(l => console.log(`  ${l.order}. ${l.id} (${l.total_sections} sections)`)); await sequelize.close();\"",
    "db:sync": "node scripts/sync-db.js",
    "db:check-scenarios": "node scripts/check-scenarios.js"
  },
  "dependencies": {
    "axios": "^1.7.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sharp": "^0.35.3",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
