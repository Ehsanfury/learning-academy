# ============================================
# 🚀 Learning Academy - Environment Variables
# ============================================

# ============================================
# 🗄️ Database
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ============================================
# 🔐 JWT
# ============================================
JWT_SECRET=your-strong-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-strong-refresh-secret-min-32-chars-different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 🔐 Session
# ============================================
SESSION_SECRET=your-session-secret-min-32-chars

# ============================================
# 🤖 AI Services
# ============================================
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_AI_MODEL=gemini-2.0-flash
FALLBACK_AI_MODEL=openrouter/gpt-4o-mini

# ============================================
# 🌐 App
# ============================================
APP_URL=http://localhost:3000
API_URL=http://localhost:5001
NODE_ENV=development
PORT=5001

# ============================================
# 🔒 CORS
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============================================
# 📧 Email (optional)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@german-academy.com

# ============================================
# 👑 Admin
# ============================================
ADMIN_EMAIL=admin@german-academy.com
ADMIN_PASSWORD=admin123456

# ============================================
# 📊 Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# 🚦 Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100