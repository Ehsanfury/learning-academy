# ============================================
# 🚀 Learning Academy - .gitignore
# ============================================

# ============================================
# 📦 Dependencies
# ============================================
node_modules/
.pnp/
.pnp.js

# ============================================
# 🔨 Build outputs
# ============================================
dist/
build/
out/
.next/
.vite/

# ============================================
# 🔐 Environment files
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# ============================================
# 📊 Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# 💻 OS files
# ============================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# 📝 IDE files
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
*.iml
.project
.classpath

# ============================================
# 🧪 Testing
# ============================================
coverage/
.nyc_output/

# ============================================
# 🔒 Security
# ============================================
*.pem
*.key
*.crt
*.p12

# ============================================
# 📦 Lock files (optional - uncomment if needed)
# ============================================
# **/package-lock.json
# **/yarn.lock

# ============================================
# 🗄️ Backend specific
# ============================================
backend/.env
backend/.env.local
backend/logs/
backend/tmp/
backend/uploads/
backend/database.sqlite
backend/database.sqlite-journal
backend/*.tgz

# ============================================
# 🎨 Frontend specific
# ============================================
src/**/*.css.map
*.tsbuildinfo