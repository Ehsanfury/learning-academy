{
  "name": "learning-academy",
  "version": "2.0.0",
  "description": "پلتفرم رایگان آموزش زبان آلمانی برای فارسی‌زبانان و انگلیسی‌زبانان",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node backend/server.js",
    "server:dev": "nodemon backend/server.js",
    "start": "node backend/server.js",
    "start:dev": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "seed": "node backend/scripts/runLessonSeeder.js",
    "seed:scenarios": "node backend/scripts/seed-all-scenarios.js",
    "lint": "eslint src/ --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "test": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "axios": "^1.7.4",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.21",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.428.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.0.1",
    "react-router-dom": "^6.26.0",
    "react-window": "^2.2.7",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
